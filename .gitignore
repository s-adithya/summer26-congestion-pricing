*.log

# --- Data: large TLC parquet files are never committed ---
*.parquet

# Raw TLC downloads — keep folder structure only
data/raw/**
!data/raw/**/
!data/raw/**/.gitkeep

# Standardized trip parquets — generated locally, too large for git
data/processed/00_standardized_trips/**
!data/processed/00_standardized_trips/**/
!data/processed/00_standardized_trips/**/.gitkeep

# Small QC CSVs and teammate sample — tracked (not ignored)
#   data/processed/qc/
#   data/processed/samples/

# Other generated artifacts
artifacts/**
!artifacts/**/
!artifacts/**/.gitkeep
